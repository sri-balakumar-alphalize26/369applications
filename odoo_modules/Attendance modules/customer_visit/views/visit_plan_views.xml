<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_visit_plan_tree" model="ir.ui.view">
        <field name="name">visit.plan.tree</field>
        <field name="model">visit.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="employee_id"/>
                <field name="visit_date"/>
                <field name="purpose_id"/>
                <field name="manager_id"/>
                <field name="approval_status"/>
                <field name="visit_status"/>
            </list>
        </field>
    </record>

    <record id="view_visit_plan_form" model="ir.ui.view">
        <field name="name">visit.plan.form</field>
        <field name="model">visit.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_for_approval" string="Send for Approval" type="object" class="btn-primary" invisible="approval_status != 'new'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="approval_status != 'pending'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="approval_status != 'pending'"/>
                    <button name="action_reset_to_new" string="Reset to New" type="object" invisible="approval_status not in ('rejected', 'pending')"/>
                    <button name="action_create_visit" string="Create Visit" type="object" class="btn-primary" invisible="approval_status != 'approved' or visit_status == 'visited'"/>
                    <field name="approval_status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="employee_id"/>
                            <field name="created_by_id"/>
                        </group>
                        <group>
                            <field name="visit_date"/>
                            <field name="purpose_id"/>
                            <field name="manager_id"/>
                            <field name="visit_status"/>
                        </group>
                    </group>
                    <group>
                        <field name="remarks"/>
                    </group>
                    <notebook>
                        <page string="Visits">
                            <field name="visit_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_visit_plan_search" model="ir.ui.view">
        <field name="name">visit.plan.search</field>
        <field name="model">visit.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="employee_id"/>
            </search>
        </field>
    </record>

    <record id="action_visit_plan" model="ir.actions.act_window">
        <field name="name">Visit Plans</field>
        <field name="res_model">visit.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_visit_plan" name="Visit Plans" parent="menu_customer_visit_root" action="action_visit_plan" sequence="20"/>

</odoo>
