<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_customer_visit_tree" model="ir.ui.view">
        <field name="name">customer.visit.tree</field>
        <field name="model">customer.visit</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="employee_id"/>
                <field name="date_time_office"/>
                <field name="purpose_id"/>
                <field name="visit_duration"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_customer_visit_form" model="ir.ui.view">
        <field name="name">customer.visit.form</field>
        <field name="model">customer.visit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_done" string="Mark as Done" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state != 'done'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="employee_id"/>
                            <field name="date_time_office"/>
                        </group>
                        <group>
                            <field name="purpose_id"/>
                            <field name="visit_duration"/>
                            <field name="visit_plan_id"/>
                            <field name="location_name"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>
                    <group>
                        <field name="remarks"/>
                    </group>
                    <notebook>
                        <page string="Images">
                            <field name="image_ids">
                                <list editable="bottom">
                                    <field name="image" widget="image" options="{'size': [200, 200]}"/>
                                    <field name="image_filename" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Voice Note">
                            <group>
                                <field name="voice_note" filename="voice_note_filename"/>
                                <field name="voice_note_filename" invisible="1"/>
                                <field name="voice_note_player" invisible="not voice_note"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_customer_visit_search" model="ir.ui.view">
        <field name="name">customer.visit.search</field>
        <field name="model">customer.visit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="employee_id"/>
            </search>
        </field>
    </record>

    <record id="action_customer_visit" model="ir.actions.act_window">
        <field name="name">Customer Visits</field>
        <field name="res_model">customer.visit</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_customer_visit" name="Customer Visits" parent="menu_customer_visit_root" action="action_customer_visit" sequence="10"/>

    <!-- NOTE: view_customer_visit_picker lives in hr_field_attendance because
         it references the source_trip_id field, which is declared in
         hr_field_attendance/models/customer_visit_inherit.py to avoid a
         circular dependency on vehicle_tracking. -->

</odoo>
