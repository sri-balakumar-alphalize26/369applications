<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_customer_visit" model="ir.sequence">
            <field name="name">Customer Visit</field>
            <field name="code">customer.visit</field>
            <field name="prefix">CV/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_visit_plan" model="ir.sequence">
            <field name="name">Visit Plan</field>
            <field name="code">visit.plan</field>
            <field name="prefix">VP/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
