<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_leave_request_list" model="ir.ui.view">
        <field name="name">hr.leave.request.list</field>
        <field name="model">hr.leave.request</field>
        <field name="arch" type="xml">
            <list string="Leave Requests"
                  decoration-success="state == 'approved'"
                  decoration-warning="state == 'pending'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state == 'cancelled'">
                <field name="employee_name"/>
                <field name="leave_type"/>
                <field name="from_date"/>
                <field name="to_date"/>
                <field name="is_half_day"/>
                <field name="number_of_days"/>
                <field name="reason"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'pending'"
                       decoration-danger="state == 'rejected'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="paid_days"/>
                <field name="unpaid_days"/>
                <field name="deduction_amount"/>
                <field name="approved_by"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_leave_request_form" model="ir.ui.view">
        <field name="name">hr.leave.request.form</field>
        <field name="model">hr.leave.request</field>
        <field name="arch" type="xml">
            <form string="Leave Request">
                <header>
                    <!-- Employee Actions -->
                    <button name="action_submit" type="object"
                            string="Submit for Approval"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_cancel" type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible="state not in ('draft', 'pending', 'approved')"
                            confirm="Are you sure you want to cancel this leave request?"/>

                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft"
                            class="btn-secondary"
                            invisible="state not in ('rejected', 'cancelled')"/>

                    <!-- Manager Actions -->
                    <button name="action_approve" type="object"
                            string="Approve"
                            class="btn-success"
                            invisible="state != 'pending'"
                            groups="hr_leave_request.group_leave_manager,base.group_system"/>

                    <button name="action_reject" type="object"
                            string="Reject"
                            class="btn-danger"
                            invisible="state != 'pending'"
                            groups="hr_leave_request.group_leave_manager,base.group_system"/>

                    <!-- Status Bar -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,approved"/>
                </header>

                <sheet>
                    <group>
                        <group string="Leave Details">
                            <field name="hr_employee_id"
                                   readonly="state != 'draft'"/>
                            <field name="leave_type"
                                   readonly="state != 'draft'"/>
                            <field name="from_date"
                                   readonly="state != 'draft'"/>
                            <field name="to_date"
                                   readonly="state != 'draft'"
                                   placeholder="Leave empty for single day"
                                   invisible="is_half_day"/>
                            <field name="is_half_day"
                                   readonly="state != 'draft'"/>
                            <field name="number_of_days" readonly="1"/>
                            <field name="paid_days" readonly="1"/>
                            <field name="unpaid_days" readonly="1"/>
                            <field name="deduction_amount" readonly="1"/>
                        </group>

                        <group string="Approval Info">
                            <field name="approved_by" readonly="1"/>
                            <field name="approval_date" readonly="1"/>
                            <field name="rejection_reason" readonly="1"
                                   invisible="state != 'rejected'"/>
                        </group>
                    </group>

                    <group string="Reason">
                        <field name="reason" nolabel="1"
                               readonly="state not in ('draft', 'pending')"
                               placeholder="Enter the reason for your leave request..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_leave_request_search" model="ir.ui.view">
        <field name="name">hr.leave.request.search</field>
        <field name="model">hr.leave.request</field>
        <field name="arch" type="xml">
            <search string="Search Leave Requests">
                <field name="employee_name"/>
                <field name="leave_type"/>
                <field name="from_date"/>
                <field name="reason"/>
                <separator/>
                <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="My Requests" name="my_requests" domain="[('employee_user_id', '=', uid)]"/>
                <separator/>
                <filter string="Date" name="date_filter" date="from_date"/>
                <group>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_user_id'}"/>
                    <filter string="Leave Type" name="group_leave_type" context="{'group_by': 'leave_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'from_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION: All Leave Requests (Manager) -->
    <record id="action_leave_request" model="ir.actions.act_window">
        <field name="name">Leave Requests</field>
        <field name="res_model">hr.leave.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No leave requests yet
            </p>
            <p>
                Employees can submit leave requests for manager approval.
            </p>
        </field>
    </record>

    <!-- ACTION: My Leave Requests (Employee) -->
    <record id="action_my_leave_requests" model="ir.actions.act_window">
        <field name="name">My Leave Requests</field>
        <field name="res_model">hr.leave.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="domain">[('employee_user_id', '=', uid)]</field>
    </record>

    <!-- ACTION: Approved Leaves Report -->
    <record id="action_approved_leaves_report" model="ir.actions.act_window">
        <field name="name">Approved Leaves Report</field>
        <field name="res_model">hr.leave.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="domain">[('state', '=', 'approved')]</field>
        <field name="context">{'search_default_group_employee': 1}</field>
    </record>

</odoo>
