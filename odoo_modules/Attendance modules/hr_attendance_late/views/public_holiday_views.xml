<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Public Holiday - Tree View -->
    <record id="view_public_holiday_tree" model="ir.ui.view">
        <field name="name">hr.public.holiday.tree</field>
        <field name="model">hr.public.holiday</field>
        <field name="arch" type="xml">
            <list string="Public Holidays" editable="bottom">
                <field name="name"/>
                <field name="date"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <!-- Public Holiday - Form View -->
    <record id="view_public_holiday_form" model="ir.ui.view">
        <field name="name">hr.public.holiday.form</field>
        <field name="model">hr.public.holiday</field>
        <field name="arch" type="xml">
            <form string="Public Holiday">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Public Holiday - Search View -->
    <record id="view_public_holiday_search" model="ir.ui.view">
        <field name="name">hr.public.holiday.search</field>
        <field name="model">hr.public.holiday</field>
        <field name="arch" type="xml">
            <search string="Public Holidays">
                <field name="name"/>
                <field name="date"/>
                <filter string="This Year" name="this_year"
                        domain="[('date', '&gt;=', (context_today()).strftime('%%Y-01-01')),
                                 ('date', '&lt;=', (context_today()).strftime('%%Y-12-31'))]"/>
                <group>
                    <filter string="Month" name="group_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Public Holiday - Action -->
    <record id="action_public_holiday" model="ir.actions.act_window">
        <field name="name">Public Holidays</field>
        <field name="res_model">hr.public.holiday</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_public_holiday_search"/>
        <field name="context">{'search_default_this_year': 1}</field>
    </record>

</odoo>
