<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Default company-wide config: 8 AM start, 15 min threshold, 5 grace late times -->
    <record id="default_late_config" model="hr.attendance.late.config">
        <field name="company_id" ref="base.main_company"/>
        <field name="office_start_hour">8.0</field>
        <field name="late_threshold_minutes">15</field>
        <field name="grace_late_times">5</field>
    </record>

    <!-- Default deduction slab: 15 min to 60 min = 100 -->
    <record id="default_slab_1" model="hr.late.deduction.slab">
        <field name="company_id" ref="base.main_company"/>
        <field name="from_minutes">15</field>
        <field name="to_minutes">60</field>
        <field name="deduction_amount">100.0</field>
    </record>

    <!-- Default deduction slab: more than 60 min = 250 -->
    <record id="default_slab_2" model="hr.late.deduction.slab">
        <field name="company_id" ref="base.main_company"/>
        <field name="from_minutes">61</field>
        <field name="to_minutes">0</field>
        <field name="deduction_amount">250.0</field>
    </record>

</odoo>
