<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fleet_vehicle_form_inherit_tank" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.tank.capacity</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>

        <field name="arch" type="xml">

            <!-- Insert Tank Capacity BELOW Chassis Number -->
            <xpath expr="//field[@name='vin_sn']" position="after">
                <field name="tank_capacity"/>
            </xpath>

        </field>
    </record>

</odoo>
