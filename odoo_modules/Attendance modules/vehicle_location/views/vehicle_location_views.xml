<odoo>
    <!-- Vehicle Location Form View -->
    <record id="view_vehicle_location_form" model="ir.ui.view">
        <field name="name">vehicle.location.form</field>
        <field name="model">vehicle.location</field>
        <field name="arch" type="xml">
            <form string="Vehicle Location">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="location"/>
                        <field name="latitude"/>
                        <field name="longitude"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vehicle Location List View -->
    <record id="view_vehicle_location_list" model="ir.ui.view">
        <field name="name">vehicle.location.list</field>
        <field name="model">vehicle.location</field>
        <field name="arch" type="xml">
            <list string="Vehicle Locations">
                <field name="name"/>
                <field name="location"/>
                <field name="latitude"/>
                <field name="longitude"/>
            </list>
        </field>
    </record>

    <!-- Define Action for Vehicle Location -->
    <record id="vehicle_location_action" model="ir.actions.act_window">
        <field name="name">Vehicle Locations</field>
        <field name="res_model">vehicle.location</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <!-- Custom Parent Menu for Vehicle Locations -->
    <menuitem id="vehicle_location_main_menu" name="Vehicle Locations" sequence="10"/>

    <!-- Vehicle Location Submenu -->
    <menuitem id="vehicle_location_menu" name="Manage Locations" parent="vehicle_location_main_menu" action="vehicle_location_action" sequence="10"/>
</odoo>
