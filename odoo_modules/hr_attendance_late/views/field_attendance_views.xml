<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dedicated LIST view for field-attendance rows -->
    <record id="view_field_attendance_list" model="ir.ui.view">
        <field name="name">hr.attendance.field.list</field>
        <field name="model">hr.attendance</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <list string="Field Attendance">
                <field name="employee_id"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="daily_total_hours" widget="float_time" string="Hours"/>
                <field name="source_trip_id" string="Trip"/>
                <field name="gps_location_name" string="Location"/>
                <field name="is_late"/>
                <field name="late_minutes_display" string="Late Time"/>
                <field name="deduction_amount"/>
                <field name="late_reason" optional="hide"/>
                <field name="is_waived" string="Waived" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Dedicated SEARCH view -->
    <record id="view_field_attendance_search" model="ir.ui.view">
        <field name="name">hr.attendance.field.search</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <search string="Field Attendance">
                <field name="employee_id"/>
                <field name="department_id" operator="child_of"/>
                <field name="source_trip_id" string="Trip"/>
                <field name="gps_location_name" string="Location"/>
                <field name="check_in"/>
                <separator/>
                <filter string="My Records" name="my_records" domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="Late Only" name="late_only" domain="[('is_late', '=', True)]"/>
                <filter string="With Deduction" name="with_deduction" domain="[('deduction_amount', '&gt;', 0)]"/>
                <filter string="Waived" name="waived" domain="[('is_waived', '=', True)]"/>
                <separator/>
                <filter string="Date" name="date_filter" date="check_in"/>
                <group>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Trip" name="group_trip" context="{'group_by': 'source_trip_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ALL Field Attendance — visible to HR / managers -->
    <record id="action_field_attendance" model="ir.actions.act_window">
        <field name="name">Field Attendance</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('attendance_source', '=', 'field')]</field>
        <field name="search_view_id" ref="view_field_attendance_search"/>
        <field name="view_id" ref="view_field_attendance_list"/>
        <field name="context">{'default_attendance_source': 'field'}</field>
    </record>

    <!-- MY Field Attendance — visible to employees, filtered to their own records -->
    <record id="action_my_field_attendance" model="ir.actions.act_window">
        <field name="name">My Field Attendance</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('attendance_source', '=', 'field'), ('employee_id.user_id', '=', uid)]</field>
        <field name="search_view_id" ref="view_field_attendance_search"/>
        <field name="view_id" ref="view_field_attendance_list"/>
        <field name="context">{'default_attendance_source': 'field'}</field>
    </record>

    <!-- Parent menu under Attendance -->
    <menuitem id="menu_field_attendance_root"
              name="Field Attendance"
              parent="hr_attendance.menu_hr_attendance_root"
              sequence="35"/>

    <!-- All Field Records — HR / managers -->
    <menuitem id="menu_field_attendance_all"
              name="All Field Records"
              parent="menu_field_attendance_root"
              action="action_field_attendance"
              sequence="10"
              groups="hr.group_hr_user,base.group_system"/>

    <!-- My Field Attendance — every employee -->
    <menuitem id="menu_my_field_attendance"
              name="My Field Attendance"
              parent="menu_field_attendance_root"
              action="action_my_field_attendance"
              sequence="20"/>

</odoo>
