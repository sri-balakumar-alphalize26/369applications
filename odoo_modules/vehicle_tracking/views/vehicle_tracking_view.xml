<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- FORM VIEW -->
  <record id="view_vehicle_tracking_form" model="ir.ui.view">
    <field name="name">vehicle.tracking.form</field>
    <field name="model">vehicle.tracking</field>
    <field name="arch" type="xml">
      <form string="Vehicle Tracking">
        <header>
          <button name="action_custom_save" string="Save" type="object" class="btn-primary"/>

          <button name="action_discard_custom"
                  string="Discard"
                  type="object"
                  class="btn-secondary"/>

          <button name="action_start_trip"
                  string="Start Trip"
                  type="object"
                  class="btn-primary oe_highlight"
                  invisible="start_trip or trip_cancel"/>
          <!-- Update Trip is gated by `is_dirty`. Odoo's button `disabled` is
               NOT reactive to in-memory field changes (only `invisible` is),
               so we hide the button until the user actually edits something.
               Once any tracked field changes, _onchange_mark_dirty flips
               is_dirty=True and the button re-appears. -->
          <button name="action_update_trip"
                  string="Update Trip"
                  type="object"
                  class="btn-primary"
                  invisible="not start_trip or end_trip or trip_cancel or not is_dirty"/>
          <button name="action_end_trip"
                  string="End Trip"
                  type="object"
                  class="btn-success oe_highlight"
                  invisible="not start_trip or end_trip or trip_cancel"/>
          <button name="action_cancel_trip"
                  string="Cancel Trip"
                  type="object"
                  class="btn-danger"
                  invisible="not start_trip or end_trip or trip_cancel"
                  confirm="Are you sure you want to cancel this trip?"/>
          <button name="action_reset_to_draft"
                  string="Reset to Draft"
                  type="object"
                  class="btn-secondary"
                  invisible="not (end_trip or trip_cancel)"
                  confirm="Reset this trip back to Draft? Lifecycle flags will be cleared."/>
        </header>
          <field name="trip_status" widget="statusbar" statusbar_visible="draft,in_progress,ended"/>
          

        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="action_view_visits"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-map-marker"
                    invisible="visited_stop_count == 0">
              <field name="visited_stop_count" widget="statinfo" string="Visits"/>
            </button>
          </div>
          <group>
            <group>
              <field name="date" required="1" readonly="end_trip or trip_cancel"/>
              <field name="vehicle_id" required="1" readonly="end_trip or trip_cancel"/>
              <field name="driver_id" required="1" readonly="end_trip or trip_cancel"/>
              <field name="number_plate" readonly="end_trip or trip_cancel"/>
            </group>
            <group>
              <field name="company_id" readonly="1"/>
              <field name="tank_capacity" readonly="1"/>
            </group>
          </group>

          <separator string="Tracking Details" colspan="2"/>

          <group>
            <group>
              <field name="source_id" placeholder="Select Source Location" required="1" readonly="end_trip or trip_cancel"/>
              <field name="start_km" required="1" readonly="start_trip or end_trip or trip_cancel"/>
              <label for="end_km"/>
              <div>
                  <field name="end_km" required="end_trip" nolabel="1"
                         readonly="not start_trip or end_trip or trip_cancel"/>
                  <div class="text-danger small mt-1" invisible="start_trip or trip_cancel">
                      After Start Trip you can use this field.
                  </div>
              </div>
              <field name="km_travelled" readonly="1"/>
              <field name="purpose_of_visit_id" required="1" readonly="end_trip or trip_cancel"/>
            </group>

            <group>
              <field name="destination_id" placeholder="Select Destination Location" required="1" readonly="end_trip or trip_cancel"/>
              <field name="visited_stops_display" readonly="1"
                     invisible="visited_stop_count == 0"/>
              <field name="start_time" readonly="end_trip or trip_cancel"/>
              <label for="end_time"/>
              <div>
                  <field name="end_time" required="end_trip" nolabel="1"
                         readonly="not start_trip or end_trip or trip_cancel"/>
                  <div class="text-danger small mt-1" invisible="start_trip or trip_cancel">
                      After Start Trip you can use this field.
                  </div>
              </div>
              <field name="duration" readonly="1"/>
              <field name="invoice_number" readonly="end_trip or trip_cancel"/>

              <field name="invoice_message"
                  readonly="1"
                  class="oe_inline"/>

              <field name="amount" readonly="end_trip or trip_cancel"/>
              <field name="estimated_time" readonly="end_trip or trip_cancel"/>
              <field name="estimated_km" readonly="end_trip or trip_cancel"/>
            </group>
          </group>
          <!-- Trip Comparison — appears once the trip is ended. Shows
               actual KM/duration alongside their variance vs the
               ORS-estimated values. Admins can sort the list view by
               km_variance / time_variance to find outlier trips. -->
          <group string="Trip Comparison" invisible="not end_trip">
            <group>
              <field name="km_travelled" readonly="1"/>
              <field name="km_variance" readonly="1"/>
            </group>
            <group>
              <field name="duration" readonly="1"/>
              <field name="time_variance" readonly="1"/>
            </group>
          </group>
          <separator string="Vehicle Checklist" colspan="2"/>
          <group col="2">
            <field name="coolant_water" readonly="end_trip or trip_cancel"/>
            <field name="oil_checking" readonly="end_trip or trip_cancel"/>
            <field name="tyre_checking" readonly="end_trip or trip_cancel"/>
            <field name="battery_checking" readonly="end_trip or trip_cancel"/>
            <field name="daily_checks" readonly="end_trip or trip_cancel"/>
            <field name="fuel_checking" readonly="end_trip or trip_cancel"/>
            <field name="fuel_status"/>
            <button name="action_add_fuel_log"
                    type="object"
                    string="+ Add Fuel"
                    class="btn btn-primary oe_highlight"
                    invisible="end_trip or trip_cancel"/>
            <separator string="Fuel List" colspan="2"/>
            <field name="fuel_log_ids" readonly="1">
              <list>
                  <field name="amount"/>
                  <field name="fuel_level"/>
                  <field name="odometer"/>
                  <field name="create_date"/>
                  <field name="driver_id"/>
              </list>
           </field>


          </group>

          <separator string="Invoice Details" colspan="2"/>
          <field name="invoice_line_ids" readonly="end_trip or trip_cancel">
            <list editable="bottom">
                <field name="name" required="1"/>
                <field name="invoice_number" required="1"/>
            </list>
          </field>
          <!-- Booleans driving the header buttons' visibility expressions.
               Must stay loaded on the form even though they are not displayed. -->
          <group invisible="1">
            <field name="start_trip"/>
            <field name="end_trip"/>
            <field name="trip_cancel"/>
            <field name="is_dirty"/>
          </group>
          <separator string="Attachment Details" colspan="2"/>
          <group>
            <field name="image_url" widget="image"
                   filename="image_filename"
                   options="{'preview_image': 'image_url'}"
                   readonly="end_trip or trip_cancel"/>
            <field name="image_filename" invisible="1"/>
          </group>
          <separator string="Remarks" colspan="2"/>
          <group>
            <field name="remarks" nolabel="1" placeholder="Enter remarks here..." readonly="end_trip or trip_cancel"/>
          </group>

        </sheet>
      </form>
    </field>
  </record>

  <!-- LIST VIEW -->
  <record id="view_vehicle_tracking_list" model="ir.ui.view">
    <field name="name">vehicle.tracking.list</field>
    <field name="model">vehicle.tracking</field>
    <field name="arch" type="xml">
      <list string="Vehicle Tracking"
            decoration-muted="trip_status == 'cancelled'"
            decoration-info="trip_status == 'in_progress'"
            decoration-success="trip_status == 'ended'">
        <field name="ref"/>
        <field name="date"/>
        <field name="vehicle_id"/>
        <field name="driver_id"/>
        <field name="number_plate"/>
        <field name="source_id"/>
        <field name="destination_id"/>
        <field name="start_km"/>
        <field name="end_km"/>
        <field name="km_travelled" sum="km_travelled"/>
        <field name="visited_stop_count" string="Stops" optional="show"/>
        <field name="end_time"/>
        <field name="duration" sum="duration"/>
        <field name="amount"/>
        <field name="trip_status" widget="badge"
               decoration-muted="trip_status == 'draft'"
               decoration-info="trip_status == 'in_progress'"
               decoration-success="trip_status == 'ended'"
               decoration-danger="trip_status == 'cancelled'"/>
      </list>
    </field>
  </record>
</odoo>
