<odoo>
    <record id="view_vehicle_fuel_log_form_popup" model="ir.ui.view">
        <field name="name">vehicle.fuel.log.form.popup</field>
        <field name="model">vehicle.fuel.log</field>
        <field name="arch" type="xml">
            <form string="Fuel Entry">
                <group>
                    <field name="vehicle_tracking_id" readonly="1"/>
                    <field name="vehicle_id" readonly="1"/>
                    <field name="driver_id" readonly="1"/>
                </group>

                <group>
                    <field name="amount" required="1"/>
                    <field name="fuel_level" required="1"/>
                </group>

                <group>
                    <field name="odometer" required="1"/>
                </group>

                <group>
                    <field name="gps_lat"/>
                    <field name="gps_long"/>
                </group>

                <group string="Images">
                    <field name="odometer_image"
                           filename="odometer_image_filename"
                           widget="image"/>
                    <field name="odometer_image_filename" invisible="1"/>
                    <field name="receipt_image"
                           filename="receipt_image_filename"
                           widget="image"/>
                    <field name="receipt_image_filename" invisible="1"/>
                </group>

                <footer>
                    <button string="Save" type="object" name="action_save_fuel_log" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
