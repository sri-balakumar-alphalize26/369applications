<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- The Vehicle Tracking module's "Purposes of Visit" menu now opens the
       SHARED visit.purpose list (defined in customer_visit). Adding a
       purpose here surfaces in BOTH the Vehicle Tracking trip form and
       the Customer Visit form — one model, one dropdown source.

       The old vehicle.purpose model + table still exist on disk for
       backward-compatibility but are no longer reachable from any menu.
       The pre-migration script in 19.0.2.x copies any leftover
       vehicle.purpose names into visit.purpose so nothing is lost. -->

  <menuitem
      id="menu_vehicle_purpose"
      name="Purposes of Visit"
      parent="vehicle_tracking.menu_vehicle_tracking_root"
      action="customer_visit.action_visit_purpose"
      sequence="20"
      groups="base.group_user"/>

</odoo>
