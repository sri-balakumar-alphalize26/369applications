<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Minimal, valid SEARCH VIEW -->
  <record id="view_vehicle_tracking_search" model="ir.ui.view">
    <field name="name">vehicle.tracking.search</field>
    <field name="model">vehicle.tracking</field>
    <field name="arch" type="xml">
      <search string="Search Vehicle Tracking">
        <!-- Keep it minimal first; we can add more fields/filters after install -->
        <field name="vehicle_id"/>
        <field name="driver_id"/>
        <field name="state"/>
        <filter name="filter_validated" string="Validated" domain="[('state','=','validated')]"/>
        <filter name="filter_draft" string="Draft" domain="[('state','=','draft')]"/>
      </search>
    </field>
  </record>

  <!-- WINDOW ACTION -->
  <record id="action_vehicle_tracking" model="ir.actions.act_window">
    <field name="name">Vehicle Tracking</field>
    <field name="res_model">vehicle.tracking</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="vehicle_tracking.view_vehicle_tracking_search"/>
    <field name="help" type="html">
      <p>Create and track vehicle trips here.</p>
    </field>
  </record>

  <!-- Reports → Fuel Entries — list of all fuel.log rows with totals
       at the bottom. Drillable into a read-only detail with images. -->
  <record id="action_fuel_entries_report" model="ir.actions.act_window">
    <field name="name">Fuel Entries Report</field>
    <field name="res_model">vehicle.fuel.log</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_vehicle_fuel_log_report_search"/>
    <field name="view_ids" eval="[
        (5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('view_vehicle_fuel_log_report_list')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('view_vehicle_fuel_log_report_form')})
    ]"/>
    <field name="help" type="html">
      <p>All fuel entries logged across trips, with totals.</p>
    </field>
  </record>

  <!-- Reports → Trip Comparison — actual vs estimated for ended trips. -->
  <record id="action_trip_comparison_report" model="ir.actions.act_window">
    <field name="name">Trip Comparison Report</field>
    <field name="res_model">vehicle.tracking</field>
    <field name="view_mode">list,form</field>
    <field name="domain">[('end_trip','=',True)]</field>
    <field name="view_ids" eval="[
        (5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('view_vehicle_tracking_comparison_list')})
    ]"/>
    <field name="help" type="html">
      <p>Comparison of actual vs estimated KM and time for ended trips.</p>
    </field>
  </record>

</odoo>
