{
  "name": "369ai",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "type": "commonjs",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "generate-app-json": "node generateAppJson.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native(-.*)?|@react-native(-community)?|expo(-.*)?|@expo(-.*)?|@expo-google-fonts/.*|@react-navigation/.*|@unimodules/.*|sentry-expo|native-base|react-native-svg|nativewind))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@screens/(.*)$": "<rootDir>/src/screens/$1",
      "^@services/(.*)$": "<rootDir>/src/services/$1",
      "^@api/(.*)$": "<rootDir>/src/api/$1",
      "^@stores/(.*)$": "<rootDir>/src/stores/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@constants/(.*)$": "<rootDir>/src/constants/$1",
      "^@utils/(.*)$": "<rootDir>/src/utils/$1",
      "^@assets/(.*)$": "<rootDir>/assets/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/",
      "/ios/",
      "/odoo_modules/"
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.1.3",
    "@gorhom/bottom-sheet": "^4",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/datetimepicker": "7.7.0",
    "@react-navigation/bottom-tabs": "^6.5.14",
    "@react-navigation/material-top-tabs": "^6.6.13",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/native-stack": "^6.9.18",
    "@shopify/flash-list": "1.6.3",
    "axios": "^1.6.7",
    "date-fns": "^3.5.0",
    "dotenv": "^16.4.5",
    "expo": "~50.0.20",
    "expo-application": "~5.8.4",
    "expo-asset": "~9.0.2",
    "expo-av": "~13.10.6",
    "expo-barcode-scanner": "~12.9.3",
    "expo-build-properties": "~0.11.1",
    "expo-camera": "~14.1.3",
    "expo-constants": "~15.4.6",
    "expo-document-picker": "~11.10.1",
    "expo-file-system": "~16.0.9",
    "expo-font": "~11.10.3",
    "expo-image-manipulator": "~11.8.0",
    "expo-image-picker": "~14.7.1",
    "expo-intent-launcher": "~10.11.0",
    "expo-local-authentication": "~13.8.0",
    "expo-location": "~16.5.5",
    "expo-network": "~5.8.0",
    "expo-print": "~12.8.1",
    "expo-sharing": "~11.10.0",
    "expo-speech": "~11.7.0",
    "expo-status-bar": "~1.11.1",
    "expo-task-manager": "~11.7.3",
    "immer": "^10.0.3",
    "lodash": "^4.17.21",
    "lottie-react-native": "6.5.1",
    "moment": "^2.30.1",
    "nativewind": "^2.0.11",
    "pako": "^2.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.6",
    "react-native-animatable": "^1.4.0",
    "react-native-animated-loader": "^1.0.0",
    "react-native-ble-plx": "^3.5.1",
    "react-native-calendars": "^1.1306.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-maps": "1.10.0",
    "react-native-modal": "^13.0.1",
    "react-native-modal-datetime-picker": "^17.1.0",
    "react-native-pager-view": "6.2.3",
    "react-native-paper": "^5.12.3",
    "react-native-reanimated": "~3.6.2",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-signature-canvas": "^4.7.2",
    "react-native-snap-carousel": "^3.9.1",
    "react-native-svg": "14.1.0",
    "react-native-svg-charts": "^5.4.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-toast-message": "^2.2.0",
