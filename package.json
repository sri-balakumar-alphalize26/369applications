    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "~12.4.0",
    "@types/jest": "^30.0.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "jest": "^29.7.0",
    "jest-expo": "~50.0.0",
    "react-test-renderer": "^18.2.0",
    "tailwindcss": "3.3.2"
  },
  "private": true
}
